# Copy this file to .env and fill in real values before running in production.

# --- Server ---
PORT=4000
NODE_ENV=development
# Comma-separated list of origins allowed to call this API (your front-end URL(s))
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:8080

# --- Sessions ---
# Long random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=30d

# --- Pi Network ---
# No secret needed client-side; the server verifies the access token by calling
# https://api.minepi.com/v2/me. Optionally override for Testnet vs Mainnet tooling.
PI_API_BASE=https://api.minepi.com

# --- Google Sign-In ---
# From Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Apple Sign In ---
# From the Apple Developer portal (Services ID used for "Sign in with Apple")
APPLE_CLIENT_ID=com.dukuduku.chat

# --- Dev-only login bypass ---
# NEVER set this to true in production. Lets you test the whole app locally
# without real Pi/Google/Apple credentials by creating a fake session directly.
ALLOW_DEV_LOGIN=true

# --- File uploads ---
# Max upload size in bytes for photos/videos (default 15MB)
MAX_UPLOAD_BYTES=15728640

# --- AI Assistant (optional) ---
# All AI features (smart replies, rewrite, grammar fix, translate, summarize,
# the in-app chat assistant, captions & stickers) work out of the box with
# zero configuration, using a fast built-in local/heuristic engine — no key
# required. To upgrade to a real LLM, set AI_PROVIDER to "openai" or
# "anthropic" and provide the matching API key below; the app automatically
# falls back to the local engine if the call fails or isn't configured.
AI_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional: override the default model for the chosen provider
AI_MODEL=
# Optional: per-request timeout (ms) before falling back to the local engine
AI_TIMEOUT_MS=8000
