    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cookie": "^0.6.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "google-auth-library": "^9.14.1",
    "helmet": "^7.1.0",
    "jose": "^4.15.9",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
