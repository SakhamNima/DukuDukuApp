  "description": "Real backend for DukuDukuChat: auth (Pi/Google/Apple token verification), REST API, SQLite persistence, realtime chat via Socket.IO.",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development ALLOW_DEV_LOGIN=true node src/server.js"
